{
  "name": "@daks.dev/svelte-iconify",
  "version": "0.2.7",
  "description": "DAKS Svelte Iconify PKG",
  "scripts": {
    "package": "svelte-kit sync && svelte-package && publint",
    "prepublishOnly": "pnpm run package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest --ui",
    "lint": "prettier --plugin=prettier-plugin-svelte --check . && eslint .",
    "format": "prettier --plugin=prettier-plugin-svelte --write ."
  },
  "devDependencies": {
    "@iconify/svelte": "^3.1.4",
    "@sveltejs/kit": "^1.25.0",
    "@sveltejs/package": "^2.2.2",
    "@types/cookie": "^0.5.2",
    "@vitest/ui": "^0.34.4",
    "cookie": "^0.5.0",
    "esm-env": "^1.0.0",
    "iconify-icon": "^1.0.8",
    "jsdom": "22.1.0",
    "publint": "^0.2.2",
    "svelte": "^4.2.0",
    "svelte-check": "^3.5.1",
    "tslib": "^2.6.2",
    "typescript": "^5.2.2",
    "vite": "^4.4.9",
    "vitest": "^0.34.4"
  },
  "peerDependencies": {
    "@iconify/svelte": "^3.1.4",
    "@sveltejs/kit": "^1.25.0",
    "iconify-icon": "^1.0.8",
    "svelte": "^4.2.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./admin": {
      "types": "./dist/admin/index.d.ts",
      "default": "./dist/admin/index.js"
    },
    "./upload": {
      "types": "./dist/admin/server.d.ts",
      "default": "./dist/admin/server.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    ">4.0": {
      "server": [
        "./dist/server.d.ts"
      ],
      "admin": [
        "./dist/admin/index.d.ts"
      ],
      "upload": [
        "./dist/admin/server.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "engines": {
    "node": ">=16.20.2",
    "pnpm": "^8.7.0"
  },
  "packageManager": "pnpm@8.7.5",
  "browserslist": [
    "last 2 version",
    "not dead"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/daks-dev/svelte",
    "directory": "packages/iconify"
  },
  "author": {
    "name": "DVA",
    "email": "mail@daks.dev",
    "url": "https://daks.dev"
  },
  "bugs": "https://github.com/daks-dev/svelte/issues",
  "homepage": "https://svelte.daks.dev/",
  "keywords": [
    "svelte",
    "sveltekit",
    "iconify"
  ]
}
