{
  "name": "@daks.dev/svelte",
  "version": "0.1.0",
  "description": "DAKS.DEV Svelte monorepo",
  "private": false,
  "scripts": {
    "check": "pnpm -r check",
    "lint": "prettier --plugin=prettier-plugin-svelte --check . && eslint .",
    "format": "prettier --plugin=prettier-plugin-svelte --write .",
    "package:recursive": "pnpm -r package --filter=./packages/*",
    "up:recursive": "pnpm -r up"
  },
  "devDependencies": {
    "@daks.dev/svelte-iconify": "workspace:^",
    "@daks.dev/svelte-yandex": "workspace:^",
    "@daks.dev/svelte.kit": "workspace:^",
    "@daks.dev/svelte.pack": "workspace:^",
    "@daks.dev/vite-imagetools": "workspace:^",
    "@playwright/test": "^1.38.0",
    "@sveltejs/eslint-config": "^6.0.4",
    "@typescript-eslint/eslint-plugin": "^6.7.2",
    "@typescript-eslint/parser": "^6.7.2",
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-markdown": "^3.0.1",
    "eslint-plugin-svelte": "^2.33.1",
    "eslint-plugin-unicorn": "^48.0.1",
    "prettier": "^3.0.3",
    "prettier-plugin-svelte": "^3.0.3",
    "svelte-check": "^3.5.1",
    "vitest": "^0.34.4"
  },
  "type": "module",
  "engines": {
    "node": ">=16.20.2",
    "pnpm": "^8.7.0"
  },
  "packageManager": "pnpm@8.7.5",
  "browserslist": [
    "last 2 version",
    "not dead"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/daks-dev/svelte"
  },
  "bugs": "https://github.com/daks-dev/svelte/issues",
  "author": {
    "name": "DVA",
    "email": "mail@daks.dev",
    "url": "https://daks.dev"
  },
  "homepage": "https://daks.dev/",
  "keywords": [
    "svelte",
    "sveltekit",
    "tailwindcss",
    "imagetools",
    "vite-imagetools",
    "vite-plugin",
    "yandex"
  ]
}
