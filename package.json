{
  "name": "@daks.dev/svelte",
  "version": "0.1.0",
  "description": "DAKS.DEV Svelte monorepo",
  "private": false,
  "scripts": {
    "check": "pnpm -r check",
    "run:prettier": "prettier --plugin=prettier-plugin-svelte --plugin=prettier-plugin-tailwindcss",
    "lint": "pnpm run:prettier --check . && eslint .",
    "format": "pnpm run:prettier --write .",
    "package:recursive": "pnpm -r package --filter=./packages/*",
    "up:recursive": "pnpm -r up"
  },
  "devDependencies": {
    "@daks.dev/svelte.sdk": "workspace:^",
    "@sveltejs/eslint-config": "^6.0.4",
    "@sveltejs/kit": "^1.27.5",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "eslint": "^8.53.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-markdown": "^3.0.1",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-svelte": "^2.35.0",
    "eslint-plugin-tailwindcss": "^3.13.0",
    "eslint-plugin-unicorn": "^48.0.1",
    "prettier": "^3.0.3",
    "prettier-plugin-svelte": "^3.1.0",
    "prettier-plugin-tailwindcss": "^0.5.7",
    "svelte": "^4.2.3",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2"
  },
  "type": "module",
  "engines": {
    "node": ">=16.20.2",
    "pnpm": "^8.7.0"
  },
  "browserslist": [
    "last 2 version",
    "not dead"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/daks-dev/svelte"
  },
  "bugs": "https://github.com/daks-dev/svelte/issues",
  "author": {
    "name": "DVA",
    "email": "mail@daks.dev",
    "url": "https://daks.dev"
  },
  "homepage": "https://daks.dev/",
  "keywords": [
    "svelte",
    "sveltekit",
    "tailwindcss",
    "imagetools",
    "vite-imagetools",
    "vite-plugin",
    "yandex"
  ]
}
